# ==============================================================================
# Safeguard Audit - Self-Hosted Environment Configuration
# ==============================================================================
# ─── Core Application ─────────────────────────────────────────────────────────
# Application ID (used for session scoping)
APP_ID="pursuitpathways"
# Secret key for signing JWT session cookies (generate a random 32+ char string)
JWT_SECRET="your-super-secret-jwt-key-change-me-in-production"
# Database connection string (MySQL/TiDB)
DATABASE_URL="mysql://user:password@host:port/database"
# OpenID of the platform owner (will automatically be granted 'admin' role)
OWNER_OPEN_ID="your-admin-user-id"

# ─── AI & LLM Integration ─────────────────────────────────────────────────────
# Option A: Google Gemini (recommended — cost-effective)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza..."
# Optional: override model (default: gemini-2.0-flash)
# LLM_MODEL="gemini-2.0-flash"

# Option B: OpenAI (alternative)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-..."
# Optional: override model (default: gpt-4o-mini)
# LLM_MODEL="gpt-4o-mini"

# Option C: Any OpenAI-compatible provider (Groq, Anthropic, local LLM, etc.)
# LLM_BASE_URL="https://api.groq.com/openai"
# OPENAI_API_KEY="your-key"
# LLM_MODEL="llama-3.3-70b-versatile"

# ─── File Storage (AWS S3 or Compatible) ──────────────────────────────────────
# Required for photo uploads, PDF generation, and generated images
S3_BUCKET_NAME="your-bucket-name"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
# Optional: Custom endpoint for S3-compatible services (e.g., Cloudflare R2, MinIO, DigitalOcean Spaces)
# S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"

# ─── Google Maps API ──────────────────────────────────────────────────────────
# Required for location search, geocoding, and distance calculations
# Get your key at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API, Geocoding API, Places API
GOOGLE_MAPS_API_KEY="AIza..."

# ─── Push Notifications (VAPID) ───────────────────────────────────────────────
# Required for Emergency Alerts (RAS) module
# Generate keys using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-public-key"
VAPID_PRIVATE_KEY="your-private-key"
